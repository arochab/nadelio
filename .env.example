# Copy this file to ".env" and fill in your real key.
# The .env file is ignored by git (see .gitignore) — it will never be published.
BRIGHTDATA_API_KEY=your_bright_data_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: POSTed with {"email": ..., "source": "brandpulse-waitlist"} on each signup
WAITLIST_WEBHOOK_URL=

# Stripe Checkout — Deep Audit paywall (5-query audit instead of the free 2).
# Leave BOTH blank in dev/demo: the payment endpoints then return a clean
# "payments not configured" error and the free flow works normally.
# STRIPE_SECRET_KEY: your Stripe secret key (sk_test_... in test, sk_live_... in live)
# STRIPE_PRICE_ID:   the Price ID of the one-time Deep Audit product (price_...)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# Optional: force the public base URL used to build Stripe success/cancel URLs.
# Leave blank to derive it from the incoming request (request.host_url).
STRIPE_SUCCESS_URL_BASE=
