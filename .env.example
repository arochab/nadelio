# Copy this file to ".env" and fill in your real key.
# The .env file is ignored by git (see .gitignore) — it will never be published.
BRIGHTDATA_API_KEY=your_bright_data_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: POSTed with {"email": ..., "source": "brandpulse-waitlist"} on each signup
WAITLIST_WEBHOOK_URL=
